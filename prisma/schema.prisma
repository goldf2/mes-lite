generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 基础数据 ====================

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  category    String
  unit        String   @default("件")
  description String?
  bom         BOM?
  processRoutes ProcessRoute[]
  stock       Stock?
  productionOrders ProductionOrder[]
  stockIns    StockIn[]
  shipments   Shipment[]
  returnOrders ReturnOrder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Material {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  spec        String?
  category    String   @default("RAW")
  unit        String
  stockUnit   String   @default("件")
  valuationUnit String @default("kg")
  conversionRate Float @default(1)
  conversionNote String?
  costingMethod String @default("WEIGHTED_AVERAGE")
  deletedAt   DateTime?
  deletedBy   String?
  stock       Stock?
  costLayers  InventoryCostLayer[]
  bomItems    BOMItem[]
  pickItems   PickItem[]
  materialIns MaterialIn[]
  productionOrders ProductionOrder[] @relation("ProductionOrderTargetMaterial")
  createdAt   DateTime @default(now())
}

// ==================== 物料清单 BOM ====================

model BOM {
  id          String   @id @default(cuid())
  productId   String   @unique
  product     Product  @relation(fields: [productId], references: [id])
  items       BOMItem[]
  version     String   @default("v1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model BOMItem {
  id          String   @id @default(cuid())
  bomId       String
  bom         BOM      @relation(fields: [bomId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  quantity    Float    @default(0)
  unit        String
  wastageRate Float    @default(0)
}

// ==================== 工艺路线 ====================

model ProcessRoute {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  name        String
  steps       ProcessStep[]
  isDefault   Boolean  @default(false)
}

model ProcessStep {
  id            String   @id @default(cuid())
  routeId       String
  route         ProcessRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stepNo        Int
  name          String
  defaultTime   Int?
  workstation   String?
  description   String?
  deletedAt     DateTime?
  deletedBy     String?
  reports       WorkReport[]
  dispatches    Dispatch[]
}

// ==================== 生产工单 ====================

model ProductionOrder {
  id            String   @id @default(cuid())
  orderNo       String   @unique
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  materialId     String?
  targetMaterial Material? @relation("ProductionOrderTargetMaterial", fields: [materialId], references: [id])
  planQty       Int
  completeQty   Int      @default(0)
  scrapQty      Int      @default(0)
  status        String   @default("DRAFT")
  
  planId        String?
  note          String?
  picks         PickItem[]
  reports       WorkReport[]
  qcRecords     QCRecord[]
  stockIns      StockIn[]
  dispatches    Dispatch[]
  costRecords   CostRecord[]
  
  startTime     DateTime?
  completeTime  DateTime?
  cancelTime    DateTime?
  cancelReason  String?
  deletedAt     DateTime?
  deletedBy     String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== 物料领用 ====================

model PickItem {
  id          String   @id @default(cuid())
  orderId     String
  order       ProductionOrder @relation(fields: [orderId], references: [id])
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  requiredQty Float    @default(0)
  reservedValuationQty Float @default(0)
  actualQty   Float    @default(0)
  actualValuationQty Float @default(0)
  conversionRateUsed Float?
  conversionSource String?
  costAmount Float @default(0)
  costingMethod String?
  costLayerConsumptions CostLayerConsumption[]
  returnedQty Float    @default(0)
  status      String   @default("PENDING")
  pickedAt    DateTime?
  pickedBy    String?
  createdAt   DateTime @default(now())
}

// ==================== 工序报工 ====================

model WorkReport {
  id          String   @id @default(cuid())
  orderId     String
  order       ProductionOrder @relation(fields: [orderId], references: [id])
  stepId      String
  step        ProcessStep @relation(fields: [stepId], references: [id])
  
  workerName  String
  workerId    String?
  
  startTime   DateTime
  endTime     DateTime?
  
  goodQty     Int      @default(0)
  badQty      Int      @default(0)
  badReason   String?
  remark      String?
  photoUrls   String?
  
  createdAt   DateTime @default(now())
}

// ==================== 质检记录 ====================

model QCRecord {
  id          String   @id @default(cuid())
  orderId     String
  order       ProductionOrder @relation(fields: [orderId], references: [id])
  checkType   String
  sampleQty   Int
  goodQty     Int
  badQty      Int
  result      String
  badReason   String?
  inspector   String
  checkedAt   DateTime @default(now())
  photos      String?
}

// ==================== 库存与入库 ====================

model Stock {
  id          String   @id @default(cuid())
  materialId  String?  @unique
  material    Material? @relation(fields: [materialId], references: [id])
  productId   String?  @unique
  product     Product?  @relation(fields: [productId], references: [id])
  
  qty         Float    @default(0)
  reservedQty Float    @default(0)
  availableQty Float   @default(0)
  valuationQty Float   @default(0)
  reservedValuationQty Float @default(0)
  availableValuationQty Float @default(0)
  totalCost    Float    @default(0)
  valuationUnitCost Float @default(0)
  stockUnitCost Float @default(0)
  
  logs        StockLog[]
}

model StockLog {
  id          String   @id @default(cuid())
  stockId     String
  stock       Stock    @relation(fields: [stockId], references: [id])
  
  type        String
  qty         Float
  beforeQty   Float
  afterQty    Float
  valuationQty Float?
  beforeValuationQty Float?
  afterValuationQty Float?
  costAmount   Float?
  beforeCostAmount Float?
  afterCostAmount Float?
  
  refType     String?
  refId       String?
  note        String?
  
  createdAt   DateTime @default(now())
  createdBy   String?
}

model StockIn {
  id          String   @id @default(cuid())
  orderId     String
  order       ProductionOrder @relation(fields: [orderId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  qty         Int
  batchNo     String?
  inDate      DateTime @default(now())
  inBy        String?
  note        String?
}

// ==================== 供应商 ====================

model Supplier {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  contact     String?
  phone       String?
  address     String?
  deletedAt   DateTime?
  deletedBy   String?
  materialIns MaterialIn[]
  createdAt   DateTime @default(now())
}

// ==================== 来料入库 ====================

model MaterialIn {
  id          String   @id @default(cuid())
  inboundNo   String   @unique
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  qty         Float
  unit        String
  valuationQty Float   @default(0)
  valuationUnit String  @default("kg")
  conversionRate Float  @default(1)
  unitPrice   Float    @default(0)
  priceBasis  String   @default("VALUATION")
  priceUnit   String?
  valuationUnitCost Float @default(0)
  stockUnitCost Float   @default(0)
  totalAmount Float    @default(0)
  batchNo     String?
  status      String   @default("PENDING")
  inboundDate DateTime @default(now())
  receivedBy  String?
  note        String?
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime @default(now())
}

model InventoryCostLayer {
  id                    String   @id @default(cuid())
  materialId            String
  material              Material @relation(fields: [materialId], references: [id])
  materialInId          String?
  stockQty              Float
  remainingStockQty     Float
  valuationQty          Float
  remainingValuationQty Float
  stockUnit             String
  valuationUnit         String
  valuationUnitCost     Float
  stockUnitCost         Float
  totalAmount           Float
  remainingAmount       Float    @default(0)
  status                String   @default("OPEN")
  createdAt             DateTime @default(now())
  consumptions          CostLayerConsumption[]

  @@index([materialId])
  @@index([materialInId])
  @@index([status])
}

model CostLayerConsumption {
  id                String   @id @default(cuid())
  pickItemId        String
  pickItem          PickItem @relation(fields: [pickItemId], references: [id], onDelete: Cascade)
  costLayerId       String
  costLayer         InventoryCostLayer @relation(fields: [costLayerId], references: [id])
  materialId        String
  stockQty          Float
  valuationQty      Float
  costAmount        Float
  stockUnitCost     Float
  valuationUnitCost Float
  restoredAt        DateTime?
  createdAt         DateTime @default(now())

  @@index([pickItemId])
  @@index([costLayerId])
  @@index([materialId])
  @@index([restoredAt])
}

// ==================== 派工管理 ====================

model Dispatch {
  id            String   @id @default(cuid())
  dispatchNo    String   @unique
  orderId       String
  order         ProductionOrder @relation(fields: [orderId], references: [id])
  stepId        String
  step          ProcessStep @relation(fields: [stepId], references: [id])
  workerName    String
  workerId      String?
  planQty       Int
  priority      String   @default("NORMAL")
  status        String   @default("PENDING")
  dispatchedAt  DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  note          String?
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime @default(now())
}

// ==================== 发货管理 ====================

model Shipment {
  id            String   @id @default(cuid())
  shipmentNo    String   @unique
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  qty           Int
  unitPrice     Float    @default(0)
  totalAmount   Float    @default(0)
  customer      String
  customerPhone String?
  address       String?
  status        String   @default("PENDING")
  shippedAt     DateTime?
  shippedBy     String?
  trackingNo    String?
  note          String?
  deletedAt     DateTime?
  deletedBy     String?
  returnOrders  ReturnOrder[]
  createdAt     DateTime @default(now())
}

// ==================== 退货管理 ====================

model ReturnOrder {
  id            String   @id @default(cuid())
  returnNo      String   @unique
  shipmentId    String?
  shipment      Shipment? @relation(fields: [shipmentId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  qty           Int
  reason        String
  status        String   @default("PENDING")
  processedAt   DateTime?
  processedBy   String?
  note          String?
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  operatorId  String?
  operatorName String?
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  beforeData  String?
  afterData   String?
  note        String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([operatorId])
  @@index([createdAt])
}

// ==================== 成本统计 ====================

model CostRecord {
  id            String   @id @default(cuid())
  orderId       String?
  order         ProductionOrder? @relation(fields: [orderId], references: [id])
  costType      String
  category      String
  amount        Float
  description   String?
  date          DateTime
  createdBy     String?
  createdAt     DateTime @default(now())
}

// ==================== 原始单据附件 ====================

model DocumentAttachment {
  id            String   @id @default(cuid())
  ownerType     String
  ownerId       String
  documentType  String   @default("ORIGINAL")
  originalName  String
  fileName      String
  mimeType      String
  size          Int
  url           String
  storagePath   String
  note          String?
  uploadedBy    String?
  isCover       Boolean  @default(false)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime @default(now())

  @@index([ownerType, ownerId])
}

// ==================== 操作人员与注册审核 ====================

model Operator {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  phone        String?
  role         String   @default("OPERATOR")
  status       String   @default("PENDING")
  approvedAt   DateTime?
  approvedBy   String?
  lastLoginAt  DateTime?
  sessions     OperatorSession[]
  permissionOverrides OperatorPermissionOverride[]
  permissionGroups OperatorPermissionGroup[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PermissionSetting {
  id        String   @id @default(cuid())
  role      String
  resource  String
  canRead   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canUpdate Boolean  @default(false)
  canDelete Boolean  @default(false)
  canGrant  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([role, resource])
  @@index([role])
}

model OperatorPermissionOverride {
  id        String   @id @default(cuid())
  operatorId String
  operator  Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  resource  String
  canRead   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canUpdate Boolean  @default(false)
  canDelete Boolean  @default(false)
  canGrant  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([operatorId, resource])
  @@index([operatorId])
}

model PermissionGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  settings    PermissionGroupSetting[]
  operators   OperatorPermissionGroup[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PermissionGroupSetting {
  id        String   @id @default(cuid())
  groupId   String
  group     PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  resource  String
  canRead   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canUpdate Boolean  @default(false)
  canDelete Boolean  @default(false)
  canGrant  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([groupId, resource])
  @@index([groupId])
}

model OperatorPermissionGroup {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  groupId    String
  group      PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([operatorId, groupId])
  @@index([operatorId])
  @@index([groupId])
}

model OperatorSession {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  operatorId  String
  operator    Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([operatorId])
}
